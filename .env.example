# Copy to .env and fill in. Never commit .env.

# Database
# Host port 5474 maps to the compose db container (5432 inside the network).
# 5432/5433 are taken by other projects on this machine.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5474/ad_assistant

# Auth
DEV_AUTH=true                 # dev shim: trust X-Dev-User header; MUST be false in prod
CF_ACCESS_TEAM_DOMAIN=        # e.g. yourteam.cloudflareaccess.com
CF_ACCESS_AUD=                # Cloudflare Access application audience tag

# Agents / knowledge library
ANTHROPIC_API_KEY=
EMBEDDING_MODEL=              # embedding model id for pgvector chunks

# Object storage (prod: Cloudflare R2 or Railway volume; dev: local path)
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# App
BACKEND_PORT=8471
FRONTEND_ORIGIN=http://localhost:5173

# --- Production (Railway) -------------------------------------------------
# Set these on the Railway service, not in a committed file.
# Full deployment guide: docs/DEPLOY.md.

# DEV_AUTH MUST be false in production. app.prod logs a prominent warning
# when it is true and a RAILWAY_* variable is present.
# DEV_AUTH=false

# Role mapping (server-side, never trusted from the client).
# Format: email:role,email:role with roles executor | admin | viewer.
# USER_ROLES=admin@example.com:admin,executor@example.com:executor,viewer@example.com:viewer

# Where the production image serves the built frontend from. Set in the
# Dockerfile; only override to serve a different build (empty disables).
# FRONTEND_DIST=/app/frontend_dist

# Railway injects PORT; uvicorn binds to it (falls back to 8471 locally).
# PORT=8471

# Backups (python -m app.cli_backup create) write to
# STORAGE_LOCAL_PATH/backups; point STORAGE_LOCAL_PATH at the mounted
# Railway volume in production, e.g. /data.
# STORAGE_LOCAL_PATH=/data
